{% extends "base.html.twig" %}

{% block title %}All Courses - Student Manager{% endblock %}

{% block body %}
    <h1>Courses</h1>
    
    <a href="{{ path('course_new') }}" class="btn btn-success">+ Add New Course</a>
    
    {% if courses|length > 0 %}
        <table>
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Title</th>
                    <th>Credits</th>
                    <th>Instructor</th>
                    <th>Capacity</th>
                    <th>Semester</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for course in courses %}
                    <tr>
                        <td><a href="{{ path('course_show', {'id': course.id}) }}">{{ course.code }}</a></td>
                        <td>{{ course.title }}</td>
                        <td>{{ course.credits }}</td>
                        <td>{{ course.instructor ?? 'N/A' }}</td>
                        <td>{{ course.capacity }}</td>
                        <td>{{ course.semester }}</td>
                        <td>
                            <a href="{{ path('course_edit', {'id': course.id}) }}" class="btn btn-primary">Edit</a>
                            <form method="POST" action="{{ path('course_delete', {'id': course.id}) }}" style="display: inline;">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>No courses found. <a href="{{ path('course_new') }}">Create one</a></p>
    {% endif %}
{% endblock %}
